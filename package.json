{
  "name": "guts",
  "version": "1.0.0",
  "description": "GUTS game/app engine, editor, and build system",
  "main": "index.html",
  "bin": {
    "guts": "bin/guts.js"
  },
  "files": [
    "bin/",
    "build/",
    "engine/",
    "global/",
    "style/",
    "projects/Editor/",
    "webpack.config.js",
    "server.js",
    "server_editor.js",
    "version.js",
    "index.html",
    "favicon.ico"
  ],
  "scripts": {
    "test": "vitest run --no-file-parallelism --config vitest.editor.config.js && vitest run --no-file-parallelism",
    "test:watch": "vitest --no-file-parallelism",
    "test:ui": "vitest --ui --no-file-parallelism",
    "test:run": "vitest run --no-file-parallelism",
    "test:game": "vitest --no-file-parallelism",
    "test:game:run": "vitest run --no-file-parallelism",
    "test:editor": "vitest --no-file-parallelism --config vitest.editor.config.js",
    "test:editor:run": "vitest run --no-file-parallelism --config vitest.editor.config.js",
    "build": "node build/build.js",
    "build:prod": "node build/build.js --production",
    "build:watch": "node build/build.js --watch",
    "build:all": "node build/build-all.js",
    "build:all:prod": "node build/build-all.js --production",
    "build:headless": "node build/build-headless.js",
    "build:headless:prod": "node build/build-headless.js --production",
    "simulations": "node projects/TurnBasedWarfare/headless.js",
    "simulations:all": "node projects/TurnBasedWarfare/headless.js --batch",
    "build:editor": "node build/build-editor.js",
    "build:editor:watch": "node build/build-editor.js --watch",
    "build:resources": "node build/copy-resources.js",
    "build:resources:all": "node build/copy-resources-all.js",
    "resources:watch": "node build/watch-resources.js",
    "dev": "webpack serve --config webpack.dev.config.js",
    "dev:server": "node server_editor.js",
    "game:server": "node build/run-server.js",
    "start": "node build/start-project.js",
    "start:editor": "node server_editor.js 8080",
    "server": "node server.js",
    "server:prod": "node server.js 8080 --prod",
    "webpack": "webpack --config webpack.config.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/preset-env": "^7.26.0",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "monaco-editor": "^0.52.0",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "multer": "^1.4.5-lts.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "style-loader": "^4.0.0",
    "three": "^0.181.0",
    "three-nebula": "^10.0.3",
    "webpack": "^5.103.0"
  },
  "devDependencies": {
    "@vitest/ui": "^3.2.4",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "html-webpack-plugin": "^5.6.3",
    "jsdom": "^27.3.0",
    "nodemon": "^3.1.11",
    "vitest": "^3.2.4",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.9",
    "utf-8-validate": "^6.0.5"
  }
}
